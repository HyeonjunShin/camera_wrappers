{
    "name": "Ubuntu (with Dockerfile)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }, 
    "runArgs": [
        "--privileged",
		"-it",
        "--device=/dev/bus/usb:/dev/bus/usb",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
    ],
    
    // "features": {},
    // "forwardPorts": [],
    "remoteUser": "vscode"
}